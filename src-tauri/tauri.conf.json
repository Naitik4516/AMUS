{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AMUS",
  "identifier": "AMUS",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build",
      "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AMUS",
        "width": 1000,
        "height": 700,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "minHeight": 700,
        "minWidth": 700,
        "shadow": false,
        "theme": "Dark",
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**/*"]
      }
    },
    "macOSPrivateApi": true,
    "enableGTKAppId": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "category": "Music",
    "license": "MPL-2.0"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZERDk4QUY2QThCOEQzRkQKUldUOTA3aW85b3JaL2VOZnBEUnJnT05NM2ZCbG1pQzBrUEQ5K0ppaDlkaUFJNzFEdWtVU0NWSzgK",
      "endpoints": ["https://github.com/Naitik4516/AMUS/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
