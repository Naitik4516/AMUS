{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AMUS",
  "identifier": "AMUS",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AMUS",
        "width": 1000,
        "height": 700,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "minHeight": 700,
        "minWidth": 700,
        "shadow": false,
        "theme": "Dark",
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**/*"]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "category": "Music",
    "license": "MPL-2.0",
    "fileAssociations": [
      {
        "ext": ["mp3"],
        "name": "MP3 Audio",
        "description": "MP3 Audio File",
        "mimeType": "audio/mpeg",
        "role": "Viewer"
      },
      {
        "ext": ["flac"],
        "name": "FLAC Audio",
        "description": "FLAC Audio File",
        "mimeType": "audio/flac",
        "role": "Viewer"
      },
      {
        "ext": ["wav"],
        "name": "WAV Audio",
        "description": "Wave Audio File",
        "mimeType": "audio/wav",
        "role": "Viewer"
      },
      {
        "ext": ["ogg"],
        "name": "OGG Audio",
        "description": "OGG Audio File",
        "mimeType": "audio/ogg",
        "role": "Viewer"
      },
      {
        "ext": ["m4a"],
        "name": "M4A Audio",
        "description": "M4A Audio File",
        "mimeType": "audio/mp4",
        "role": "Viewer"
      },
      {
        "ext": ["aac"],
        "name": "AAC Audio",
        "description": "AAC Audio File",
        "mimeType": "audio/aac",
        "role": "Viewer"
      },
      {
        "ext": ["opus"],
        "name": "Opus Audio",
        "description": "Opus Audio File",
        "mimeType": "audio/opus",
        "role": "Viewer"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZERDk4QUY2QThCOEQzRkQKUldUOTA3aW85b3JaL2VOZnBEUnJnT05NM2ZCbG1pQzBrUEQ5K0ppaDlkaUFJNzFEdWtVU0NWSzgK",
      "endpoints": ["https://github.com/Naitik4516/AMUS/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
