{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "mini-player-capability",
  "description": "Capability for the mini-player window",
  "windows": ["mini-player"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-set-always-on-top",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus"
  ]
}
